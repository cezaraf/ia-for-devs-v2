@baseUrl = http://localhost:8080

### 1. Initialize  (captura o Mcp-Session-Id no header da resposta)
# @name initialize
POST {{baseUrl}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 1,
  "method": "initialize",
  "params": {
    "protocolVersion": "2025-06-18",
    "capabilities": {},
    "clientInfo": { "name": "vscode-rest-client", "version": "1.0.0" }
  }
}

###

@sessionId = {{initialize.response.headers.Mcp-Session-Id}}

### 2. Initialized (notification)
POST {{baseUrl}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
Mcp-Session-Id: {{sessionId}}

{
  "jsonrpc": "2.0",
  "method": "notifications/initialized"
}

### 3. List Tools  (deve aparecer get_random_number)
POST {{baseUrl}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
Mcp-Session-Id: {{sessionId}}

{
  "jsonrpc": "2.0",
  "id": 2,
  "method": "tools/list",
  "params": {}
}

### 4. Call get_random_number  -> "Número aleatório: <0-999>"
POST {{baseUrl}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
Mcp-Session-Id: {{sessionId}}

{
  "jsonrpc": "2.0",
  "id": 3,
  "method": "tools/call",
  "params": {
    "name": "get_random_number",
    "arguments": {}
  }
}
